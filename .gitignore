# OS
.DS_Store

# Runtime state (changes constantly, not config)
**/.openclaw/workspace-state.json
**/.clawhub/lock.json

# Memory files (personal data, large)
memory/

# Media and temp files
media/
temp/
*.wav
*.mp3
*.ogg

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node
node_modules/

# Inter-agent inbox messages (transient)
shared/inbox/**/*.json

# Data files (task logs, session data)
data/
!apps/dashboard/data/
apps/dashboard/data/*
!apps/dashboard/data/tasks.json
!apps/dashboard/data/workflow-runs.json

# Research temp files
research/tmp/

# Watchdog secrets
scripts/.watchdog.env

# Specs
openclaw-dashboard-specs.md

# iOS build artifacts
*.xcodeproj
apps/ios/Local.xcconfig

# Thoughts system - personal notes are private
thoughts/anthony/
thoughts/searchable/

# Local dashboard env
apps/dashboard/.env.local
# Next build output
apps/dashboard/.next/

# Python cache artifacts for local automation CLIs
apps/drive/__pycache__/
apps/steer/__pycache__/

# Local job state for listen/direct verification
apps/listen/jobs/

# Local custom workflow templates for listen
apps/listen/templates.json
