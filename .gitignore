# OS
.DS_Store

# Runtime state (changes constantly, not config)
**/.openclaw/workspace-state.json
**/.clawhub/lock.json

# Memory files (personal data, large)
memory/

# Media and temp files
media/
temp/
*.wav
*.mp3
*.ogg

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node
node_modules/

# Inter-agent inbox messages (transient)
shared/inbox/**/*.json

# Data files (task logs, session data)
data/
!dashboard/data/
dashboard/data/*
!dashboard/data/tasks.json
!dashboard/data/workflow-runs.json

# Research temp files
research/tmp/

# Specs
openclaw-dashboard-specs.md
