{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openclaw/event-envelope",
  "type": "object",
  "required": ["eventId", "sequence", "eventType", "entityId", "emittedAt", "payload"],
  "properties": {
    "eventId": { "type": "string", "minLength": 1 },
    "sequence": {
      "type": "integer",
      "minimum": 0
    },
    "eventType": { "type": "string", "minLength": 1 },
    "entityId": { "type": "string", "minLength": 1 },
    "emittedAt": {
      "type": "string",
      "format": "date-time"
    },
    "payload": { "type": "object" }
  },
  "additionalProperties": false
}
