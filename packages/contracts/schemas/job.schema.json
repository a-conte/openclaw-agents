{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openclaw/job",
  "type": "object",
  "required": [
    "id",
    "prompt",
    "targetAgent",
    "status",
    "createdAt"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "prompt": { "type": "string" },
    "targetAgent": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "completed", "failed", "stopped"]
    },
    "priority": {
      "type": "string",
      "enum": ["normal", "high", "urgent"]
    },
    "mode": {
      "type": "string",
      "enum": ["agent", "shell", "steer", "drive", "workflow", "note"]
    },
    "command": {
      "type": ["string", "null"]
    },
    "workflow": {
      "type": ["string", "null"]
    },
    "workflowSpec": {
      "type": ["object", "null"]
    },
    "templateId": {
      "type": ["string", "null"]
    },
    "templateInputs": {
      "type": ["object", "null"],
      "additionalProperties": {
        "type": "string"
      }
    },
    "args": {
      "type": "array",
      "items": { "type": "string" }
    },
    "thinking": {
      "type": ["string", "null"]
    },
    "local": {
      "type": "boolean"
    },
    "updates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["at", "message"],
        "properties": {
          "at": { "type": "string", "format": "date-time" },
          "message": { "type": "string" },
          "level": { "type": "string", "enum": ["info", "error"] },
          "stepId": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "summary": { "type": "string" },
    "stepStatus": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "status"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "running", "completed", "failed", "skipped"] },
          "dangerous": { "type": "boolean" },
          "startedAt": { "type": "string", "format": "date-time" },
          "completedAt": { "type": "string", "format": "date-time" },
          "result": {},
          "error": { "type": "string" },
          "artifacts": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "output": { "type": "string" },
              "stdout": { "type": "string" },
              "stderr": { "type": "string" },
              "rawOutput": { "type": "string" },
              "exitCode": { "type": "number" },
              "session": { "type": "string" },
              "screenshot": { "type": "string" },
              "image": { "type": "string" },
              "snapshotId": { "type": "string" },
              "snapshotPath": { "type": "string" },
              "path": { "type": "string" },
              "match": { "type": "string" },
              "token": { "type": "string" },
              "clicked": { "type": "object", "additionalProperties": true },
              "target": { "type": "object", "additionalProperties": true },
              "matches": {
                "type": "array",
                "items": { "type": "object", "additionalProperties": true }
              }
            }
          }
        },
        "additionalProperties": false
      }
    },
    "currentStepId": {
      "type": ["string", "null"]
    },
    "timedOut": {
      "type": "boolean"
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "retryOf": {
      "type": ["string", "null"]
    },
    "retryMode": {
      "type": ["string", "null"],
      "enum": ["resume_failed", "resume_from", "rerun_all", null]
    },
    "resumeFromStepId": {
      "type": ["string", "null"]
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "jobId": { "type": "string" },
          "attempt": { "type": "integer", "minimum": 1 },
          "status": { "type": "string" },
          "mode": { "type": "string" },
          "resumeFromStepId": { "type": ["string", "null"] },
          "completedAt": { "type": "string", "format": "date-time" },
          "summary": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "policy": {
      "type": "object",
      "required": ["allowed"],
      "properties": {
        "allowed": { "type": "boolean" },
        "reason": { "type": "string" },
        "allowDangerous": { "type": "boolean" },
        "allowedSteerCommands": { "type": "array", "items": { "type": "string" } },
        "allowedDriveCommands": { "type": "array", "items": { "type": "string" } },
        "allowedWorkflows": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    },
    "result": {},
    "error": { "type": "string" }
  },
  "additionalProperties": false
}
