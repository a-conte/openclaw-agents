{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openclaw/job",
  "type": "object",
  "required": [
    "id",
    "prompt",
    "targetAgent",
    "status",
    "createdAt"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "prompt": { "type": "string" },
    "targetAgent": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "completed", "failed", "stopped"]
    },
    "priority": {
      "type": "string",
      "enum": ["normal", "high", "urgent"]
    },
    "mode": {
      "type": "string",
      "enum": ["agent", "shell", "steer", "drive", "workflow", "note"]
    },
    "command": {
      "type": ["string", "null"]
    },
    "workflow": {
      "type": ["string", "null"]
    },
    "args": {
      "type": "array",
      "items": { "type": "string" }
    },
    "thinking": {
      "type": ["string", "null"]
    },
    "local": {
      "type": "boolean"
    },
    "updates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["at", "message"],
        "properties": {
          "at": { "type": "string", "format": "date-time" },
          "message": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "summary": { "type": "string" },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    },
    "result": {},
    "error": { "type": "string" }
  },
  "additionalProperties": false
}
