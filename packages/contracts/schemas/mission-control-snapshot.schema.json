{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openclaw/mission-control-snapshot",
  "type": "object",
  "required": ["sequence", "generatedAt", "agents", "counts"],
  "properties": {
    "sequence": { "type": "integer", "minimum": 0 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agentId"],
        "properties": {
          "agentId": { "type": "string", "minLength": 1 },
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["online", "warning", "offline"] },
          "lastActivity": { "type": "number" }
        },
        "additionalProperties": false
      }
    },
    "counts": {
      "type": "object",
      "required": ["quietAgents", "staleTasks", "failedRuns", "inProgressTasks", "dirtyRepos", "radarCount"],
      "properties": {
        "quietAgents": { "type": "integer", "minimum": 0 },
        "staleTasks": { "type": "integer", "minimum": 0 },
        "failedRuns": { "type": "integer", "minimum": 0 },
        "inProgressTasks": { "type": "integer", "minimum": 0 },
        "dirtyRepos": { "type": "integer", "minimum": 0 },
        "radarCount": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
